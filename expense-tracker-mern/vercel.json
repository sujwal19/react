{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "rewrites": [
    {
      "source": "/api/v1/transactions/(.*)",
      "destination": "server.js"
    },
    {
      "source": "/api/v1/transactions",
      "destination": "server.js"
    },
    {
      "source": "/(.*)",
      "destination": "client/$1"
    }
  ]
}